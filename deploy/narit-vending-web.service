[Unit]
Description=Narit Vending Machine Web Controller
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/admin/NaritVending
ExecStart=/home/admin/NaritVending/.venv/bin/python3 -m narit_vending.webapp --host 0.0.0.0 --port 80 --config /home/admin/NaritVending/machine_config.json
Restart=always
RestartSec=2
User=root

[Install]
WantedBy=multi-user.target
